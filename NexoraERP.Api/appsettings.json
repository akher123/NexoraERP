{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Master": "Server=localhost;Database=NexoraERP_Master;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "SigningKey": "",
    "Issuer": "NexoraERP",
    "Audience": "NexoraERP.Api",
    "AccessTokenExpirationMinutes": 60,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "RequireHttpsMetadata": false
  },
  "MultiTenancy": {
    "BaseDomain": "localhost",
    "EnableSubdomainResolution": true,
    "ExcludedPathPrefixes": [ "/health", "/swagger", "/openapi", "/api/v1/system" ]
  },
  "SampleTenant": {
    "ConnectionString": "Server=localhost;Database=NexoraERP_Tenant_Sample;Trusted_Connection=True;TrustServerCertificate=True"
  }
}
